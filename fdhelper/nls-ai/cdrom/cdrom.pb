# Language: Brazil Port.
# File ending: PB
# Codepage: 858
# This translation was made by Google Gemini.
# Please help the FreeDOS group to improve it.

CD.INIT=Inicialização do CD-ROM.
CD.GIVEUP=/p /fLightRed "não foi possível carregar um driver de CD/DVD apropriado" /fGrey
CD.ERROR=, /fGrey erro "#%1" - /fLightRed falhou /fGrey /p
CD.NO_DRVR= /fGrey não foi possível localizar o driver de CD /fYellow "%1" /fGrey - /fLightRed falhou /fGrey
CD.TRY_DRVR= /g tentando usar o driver de CD /fYellow "%1" /fGrey
CD.TRY_CACHE= /g tentando carregar o /fYellow "%1" /fGrey para cache
CD.TRY_EXT= tentando carregar as extensões de CD /fYellow "%1" /fGrey
CD.SUCCESS=, /fLightGreen sucesso /fGrey
CD.STATUS=o driver de CD e as extensões foram iniciados com sucesso para a unidade /fLightGreen "%1" /fDarkGrey (%2) /fGrey

CD.DRIVE=CD-ROM configurado como unidade /fLightGreen %1 /fGrey /fDarkGrey (%2) /fGrey
CD.NONE=/fLightRed CD-ROM não configurado /fGrey

NO_HELP=não foi possível localizar o arquivo de ajuda
