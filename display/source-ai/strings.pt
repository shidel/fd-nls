; Language: Portuguese
; File ending: PT
; Codepage: 860
; This translation was made by Google Gemini.
; Please help the FreeDOS group to improve it.

; Miscellaneous DISPLAY loading error messages
errAlready       DB     "DISPLAY já está carregado", 0dH, 0aH, "$"
errNoDRDOS       DB     "FD-DISPLAY é incompatível com esta versäo de DR-KEYB", 0dH, 0aH, "$"
sMemAllocatedBuffers
                 DB     "Buffers alocados: $"
sInTPA           DB     " em TPA, $"
sInXMS           DB     " em XMS$"

; Hardware-driver specific messages
errAcient        DB     "DISPLAY: é necessário pelo menos um adaptador EGA para este tipo de hardware", 0dH, 0aH, "$"
errNoCGA         DB     "DISPLAY: adaptador CGA näo encontrado", 0dH, 0aH, "$"
errDrvSpecific   DB     "DISPLAY: erro crítico específico do controlador", 0dH, 0aH, "$"

; Command line parsing error messages
SyntaxErrorStr:         DB      "Erro de sintaxe ($"
SES_ParamRequired       DB      ") Falta um parâmetro obrigatório", 0dH, 0aH, "$"
SES_UnexpectedEOL       DB      ") Fim de linha inesperado", 0dH, 0aH, "$"
SES_IllegalChar         DB      ") Carácter ilegal", 0dH, 0aH, "$"
SES_NameTooLong         DB      ") Nome do controlador de dispositivo demasiado longo", 0dH, 0aH, "$"
SES_OpenBrExpected      DB      ") ( esperado", 0dH, 0aH, "$"
SES_WrongHwName         DB      ") Nome de dispositivo de hardware desconhecido", 0dH, 0aH, "$"
SES_CommaExpected       DB      ") , esperado", 0dH, 0aH, "$"
SES_CloseBrExpected     DB      ") ) esperado", 0dH, 0aH, "$"
SES_WrongNumberPars     DB      ") Número de parâmetros incorreto", 0dH, 0aH, "$"
SES_TooManyPools        DB      ") Demasiadas páginas de códigos de software (MćX=5)", 0dH, 0aH, "$"
SES_ListTooLong         DB      ") A lista é demasiado longa", 0dH, 0aH, "$"
SES_TooManyHWPools      DB      ") Demasiadas páginas de códigos de hardware", 0dh, 0ah, "$"
SES_NoAllocatedBufs     DB      ") Memória insuficiente para alocar qualquer buffer", 0dH, 0aH, "$"
SES_InvalidParameter    DB      ") Parâmetro inválido", 0dh, 0ah, "$"

