1.0:An
1.1:\040:\040
1.2:O.K.?\040
1.3:Chyba vstupu
1.4:%s: načten %lu řádek\n
1.5:%s: načteno %lu řádků\n
1.6:%s: zapsán %lu řádek\n
1.7:%s: zapsáno %lu řádků\n
1.8:%lu:%c%s\n
1.9:Stiskněte <Enter> pro pokračování
1.10:%lu:\040
1.11:Nenalezeno
1.12:%lu: %s\n
1.13:\nedlin má následující podprogramy:\n
1.14:#                 upravit jeden řádek     [#],[#],#m        přesunout
1.15:a                 přidat                  [#][,#]p          stránka
1.16:[#],[#],#,[#]c    kopírovat               q                 ukončit
1.17:[#][,#]d          smazat                  [#][,#][?]r$,$    nahradit
1.18:e<>               konec (uložit & ukončit) [#][,#][?]s$      hledat
1.19:[#]i              vložit                  [#]t<>            přenést
1.20:[#][,#]l          vypsat                  [#]w<>            zapsat\n
1.21:kde výše uvedené $ je řetězec, <> je název souboru,
1.22:# je číslo (může být . = aktuální řádek, $ = poslední řádek,
1.23:nebo číslo + či - jiné číslo).\n
