HELP_14=/n
HELP_15=/n

# Error Messages
ERROR_CRITICAL=/fLightRed "Erro CRÍTICO:" /fGray /c32
ERROR_NoHDD="Não foi possível localizar uma unidade de disco rígido particionada e formatada."
ERROR_MINOR=/fLightRed "erro:" /fGray /c32
ERROR_Option="Opção de linha de comandos desconhecida ou inválida" /s- "`" /fWhite %1 /fGray "'."
ERROR_NoCfgEnv="Não foi possível determinar as definições básicas do sistema e caminhos."
ERROR_NotFreeCOM="Este ficheiro batch requer o FreeCOM ou shell compatível para FreeDOS."
ERROR_MissingFreeCOM="Não foi possível localizar a shell de comandos do FreeDOS (FreeCOM)."
ERROR_MissingAUTOEXEC="Não foi possível localizar o ficheiro de arranque do FreeDOS (FDAUTO.BAT)."
ERROR_MakeDir="Não foi possível criar o diretório" /fWhite %1 /fGray /s- .
ERROR_BackupCfg="Não foi possível fazer cópia de segurança dos ficheiros de arranque e/ou config."
ERROR_BackupOS="Não foi possível fazer cópia de segurança dos ficheiros no diretório de destino."
ERROR_Partition="Ocorreu um erro de particionamento. Um disco rígido pode não estar presente" /p "ou pode estar invisível para o sistema operativo atual." /p /p "É necessário um método diferente para o particionamento."
ERROR_NoPartition="Não foi possível localizar a partição BIOS para" /fWhite %1 /fGray /s- . /s+ /p "Instalação manual (ou talvez modo avançado sem MBR forçado) é recomendada."
ERROR_Format="Ocorreu um erro ao tentar formatar a unidade" /fWhite %1 /fGray /s- . /s+ /p /p "Será necessário um processo diferente para a formatar."
ERROR_FileSystem="Não foi possível inicializar o espaço temporário na unidade" /fWhite %1 /s- /fGray .
ERROR_CfgBackup="Não foi possível configurar o diretório de cópia de segurança."
ERROR_MBRBackup="Não foi possível criar a cópia de seg. do Master Boot Record da unidade" /fWhite %1 /fGray /s- .
ERROR_SysFiles="Não foi possível copiar os ficheiros de sistema para a unidade" /fWhite %1 /fGray /s- .
ERROR_BootSector="Não foi possível atualizar o setor de arranque da unidade" /fWhite %1 /fGray /s- .
ERROR_MBRUpdate="Não foi possível atualizar o MBR da unidade" /fWhite %1 /fGray /s- .
ERROR_Activate="Não foi possível definir a unidade" /fWhite %1 /fGray "para a partição de arranque" /fWhite %2 /fGray /s- .
ERROR_CfgFiles="Não foi possível instalar novos ficheiros de configuração na unidade" /fWhite %1 /fGray /s- .
ERROR_XfrFiles="Não foi possível duplicar o ficheiro do instalador necessário para" /fWhite %1 /fGray /s- .
ERROR_SAF="Ocorreu um problema ao extrair o arquivo" /fWhite %1 /fGray "."
ERROR_WTF="Ocorreu um erro desconhecido e improvável durante uma operação simples."
