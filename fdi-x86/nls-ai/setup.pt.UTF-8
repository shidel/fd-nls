# Help screen
HELP_0="utilização: SETUP.BAT [opções] [destino]"
HELP_1=""
HELP_2="  [sem opções]    realiza a configuração usando os padrões"
HELP_3=
HELP_4="  adv             inicia a configuração no modo avançado (mais avisos)"
HELP_5=
HELP_6="  auto            realiza a instalação automática sem avisos." /p/r18/c32 "não é recomendado e deve ser usado apenas em hardware" /p/r18/c32 "sem um sistema operativo pré-existente."
HELP_7=
HELP_8="  [destino]       define uma unidade e/ou caminho para a instalação"
HELP_9=
HELP_10="  info            exibe as definições do instalador e sai"
HELP_11=
HELP_12="  mbr             força uma atualização no MBR e sai"
