# Welcome Message
WELCOME_DEF="Velkomin í" /fLightGreen %1 /fCyan %2 /fGray "uppsetningarforritið."
WELCOME_ADV="Velkomin í" /fLightRed "ítarlega" /fGray "uppsetningu fyrir" /fLightGreen %1 /fCyan %2 /fGray /s- .
WELCOME_0=/p
WELCOME_1=/fLightGreen "%1" /fGray "er fullbúið stýrikerfi. Ef þú velur að setja þetta upp á" /p "tölvunni þinni, gætir þú " /fLightRed /BlinkOn "skrifað yfir" /BlinkOff /fGray "stýrikerfið sem fyrir er" /p "(til dæmis Windows.)" /fGray
WELCOME_2=/fGray /c32 "Ef þetta er ekki ætlun þín, vinsamlegast" /fLightRed "hættu NÚNA!" /fGray
