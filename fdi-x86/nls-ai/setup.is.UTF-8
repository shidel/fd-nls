PARTITION_DONE=/p "Þú verður að endurræsa tölvuna svo nýja skiptingin taki gildi."

FORMAT="Drif" /fWhite %1 /fGray "virðist ekki vera sniðið (formatted)."
FORMAT_DEF="Viltu sníða drifið þitt" /c32
FORMAT_ADV="Hvernig viltu sníða drifið þitt" /s- /c32 ( /fWhite "F" /fGray "ullt," /c32 /fWhite "S" /fGray "nöggt," /c32 /fWhite "N" /fGray "ei)" /c32

FILESYSTEM_TEST="Prófa skráarkerfi á drifi" /fWhite %1 /s- /fGray .
