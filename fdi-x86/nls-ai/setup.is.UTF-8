BACKUP_OLD="Fyrra stýrikerfi fannst á drifi" /fWhite %1 /fGray /s- . /s+ /p "Viltu taka öryggisafrit af gömlu skránum fyrir uppsetningu" /c32
BACKUP_ASK="Hvar viltu geyma öryggisafritin?" /c32
