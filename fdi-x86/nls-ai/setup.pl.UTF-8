STATUS_CFG=/r4/c32 "Kopiuj pliki konfig." /fWhite %1 /fGray

INSTALL_NOW="Jesteśmy gotowi do instalacji systemu" /fLightGreen %1 /fCyan %2 /fGray /s- .
EXTRACTION="Rozpakowywanie plików systemu" /fLightGreen %1 /fCyan %2 /fGray /s- .
