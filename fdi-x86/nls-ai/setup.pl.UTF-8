# Welcome Message
WELCOME_DEF="Witaj w programie instalacyjnym systemu" /fLightGreen %1 /fCyan %2 /fGray "."
WELCOME_ADV="Witaj w" /fLightRed "zaawansowanym" /fGray "instalatorze systemu" /fLightGreen %1 /fCyan %2 /fGray /s- .
WELCOME_0=/p
WELCOME_1=/fLightGreen "%1" /fGray "to kompletny system operacyjny. Jeśli zdecydujesz się go" /p "zainstalować, możesz " /fLightRed /BlinkOn "nadpisać" /BlinkOff /fGray "obecny system operacyjny" /p "(na przykład Windows)." /fGray
WELCOME_2=/fGray /c32 "Jeśli nie jest to Twoim zamiarem, proszę" /fLightRed "zatrzymaj się TERAZ!" /fGray
WELCOME_3=
WELCOME_4=
WELCOME_5=/fGray /p

HRULE=/fDarkGray /x 0xC4 /fGray

CONTINUE=/p "Czy chcesz kontynuować" /c32
REBOOT=/p "Czy chcesz teraz zrestartować komputer" /c32

AUTO_YES="[T,N]?" /fWhite "T" /fGray
AUTO_NO="[T,N]?" /fWhite "N" /fGray
AUTO_FMT=/s- "[P,S,N]?" /fWhite "S" /fGray

PROMPT_YESNO=/s TN
PROMPT_FMT=/s PSN

ABORTED=/fLightRed "Instalacja systemu" %1 %2 "została przerwana." /e /fGray /bBlack

PARTITION_AUTO="Automatycznie partycjonuj napęd" /fWhite %1 /s- /fGray .
PARTITION_WARN=/fYellow "UWAGA:" /fGray "Partycja FAT16 poniżej 2GB jest wymagana dla KERNL86."
PARTITION_MBR="Aktualizuj Master Boot Record na napędzie" /fWhite %1 /s- /fGray .
PARTITION_ACTIVE="Ustaw partycję napędu" /fWhite %1 /fGray "jako aktywną."
PARTITION_DONE=/p "Musisz zrestartować komputer, aby nowy schemat partycjonowania wszedł w życie."

FORMAT="Napęd" /fWhite %1 /fGray "nie wydaje się być sformatowany."
FORMAT_DEF="Czy chcesz sformatować napęd" /c32
FORMAT_ADV="Jak chcesz sformatować napęd" /s- /c32 ( /fWhite "P" /fGray "ełne," /c32 /fWhite "S" /fGray "zybkie," /c32 /fWhite "N" /fGray "ie)" /c32

FILESYSTEM_TEST="Testowanie systemu plików na napędzie" /fWhite %1 /s- /fGray .
INSERT_DISKETTE="Włóż dyskietkę" /fWhite #%1 /fGray (%2) "do" /fWhite %3 /fGray "."
PRESS_KEY="Naciśnij dowolny klawisz, aby kontynuować."

TARGET_ASK="Gdzie chcesz zainstalować system" /fLightGreen %1 /s- /fGray "?" /c32
TARGET_PROMPT=/fWhite /bBlue %1
TARGET_BAD=/fLightRed "Zażądano nieprawidłowego napędu. Nie można instalować na dyskietce."

CHANGE_PATH="Ścieżka" /fWhite %1 /fGray "już istnieje." /p "Czy chcesz zmienić katalog instalacyjny" /c32

BACKUP_OLD="Na napędzie" /fWhite %1 /fGray "wykryto poprzedni system operacyjny." /s+ /p "Czy chcesz utworzyć kopię zapasową starych plików przed instalacją" /c32
BACKUP_ASK="Gdzie chcesz umieścić pliki kopii zapasowej?" /c32
BACKUP_PROMPT=/fWhite /bBlue %1
BACKUP_BAD=/fLightRed "Zażądano nieprawidłowego celu. Nie można utworzyć kopii zapasowej w tej lokalizacji." /fGray

DELETE_OLD="Istniejące pliki w" /fWhite %1 /fGray "mogą zostać po prostu nadpisane." /p "Czy chcesz całkowicie skasować stary katalog przed instalacją" /c32

FORCE_MBR="Wymuś aktualizację Master Boot Record na napędzie" /fWhite %1 /fGray /c32
SYS_FILES="Zainstaluj nowe pliki startowe systemu na napędzie" /fWhite %1 /fGray /c32
CFG_FILES="Zastąp pliki konfiguracyjne systemu na napędzie" /fWhite %1 /fGray /c32

STATUS_MSG="Ustawienia instalacji:" /p
STATUS_CPU=/r4/c32 "Platforma (CPU)" /fWhite %1 /fGray (%2)
