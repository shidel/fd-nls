DO_BACKUP="Tworzenie kopii zapasowej poprzedniego OS do" /fWhite %1 /fGray /s- .
DO_ERASE="Usuwanie starego katalogu" /fWhite %1 /fGray " i plików."
DO_SYSFILES="Przenoszenie nowych plików systemowych na napęd" /fWhite %1 /fGray /s- .
DO_FORCEMBR="Wymuszona aktualizacja MBR na napędzie" /fWhite %1 /fGray /s- .
DO_ACTIVATE="Ustawianie aktywnej partycji startowej na dysku" /fWhite %1 /fGray "dla partycji" /fWhite %2 /s- /fGray .
DO_CFGFILES="Przenoszenie nowych plików konfiguracyjnych na napęd" /fWhite %1 /fGray /s- .
DO_PREPARE="Przygotowanie do instalacji plików wykonywalnych i narzędzi."
DO_INSTALL="Instalacja plików" /fLightGreen %1 /fGray "dla" /fWhite %2 /fGray /s- .

DONE_NOW="Instalacja systemu" /fLightGreen %1 /fCyan %2 /fGray "zakończona pomyślnie."
REBOOT_NOW="Czy chcesz teraz zrestartować komputer" /c32

REMOVE_MEDIA="Powinieneś teraz wyjąć wszystkie dyskietki i płyty CD."

