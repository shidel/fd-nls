# Help screen
HELP_0="uzado: SETUP.BAT [opcioj] [celo]"
HELP_1=""
HELP_2="  [neniu opcio]  plenumi instaladon uzante defaŭltojn"
HELP_3=
HELP_4="  adv            lanĉi instaladon en progresinta reĝimo (pli da demandoj)"
HELP_5=
HELP_6="  auto           plenumi tute aŭtomatan instaladon sen demandoj." /p/r18/c32 "tio ne estas rekomendinda kaj devus esti uzata nur sur aparataro" /p/r18/c32 "sen jam ekzistanta operaciumo."
HELP_7=
HELP_8="  [celo]         antaŭagordi diskon kaj/aŭ vojon por la celinstalo"
HELP_9=
HELP_10="  info           montri agordojn de la instalilo kaj eliri"
HELP_11=
