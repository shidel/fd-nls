HELP_15=/n

# Error Messages
ERROR_CRITICAL=/fLightRed "KRITIKA eraro:" /fGray /c32
ERROR_NoHDD="Ne eblas trovi particiitan kaj formatitan fiksdiskon."
ERROR_MINOR=/fLightRed "eraro:" /fGray /c32
ERROR_Option="Nekonata aŭ nevalida komandlinia opcio" /s- "`" /fWhite %1 /fGray "'."
ERROR_NoCfgEnv="Ne eblas determini bazan sistemagordon kaj vojagordojn."
ERROR_NotFreeCOM="Ĉi tiu grupodosiero postulas FreeCOM aŭ kongruan ŝelon por FreeDOS."
ERROR_MissingFreeCOM="Ne eblas trovi la komandŝelon de FreeDOS (FreeCOM)."
ERROR_MissingAUTOEXEC="Ne eblas trovi la sistemlanĉan dosieron de FreeDOS (FDAUTO.BAT)."
ERROR_MakeDir="Ne eblas krei dosierujon" /fWhite %1 /fGray /s- .
ERROR_BackupCfg="Ne eblas sekurkopii lanĉajn 'kaj/aŭ' agordajn dosierojn."
ERROR_BackupOS="Ne eblas sekurkopii dosierojn en celdosierujo."
ERROR_Partition="Eraro de particiado okazis. Fiksdisko eble ne ĉeestas aŭ" /p "estas nevidebla por la nuna operaciumo." /p /p "Malsama metodo por particiado estas bezonata."
ERROR_NoPartition="Ne eblas trovi la BIOS-particion por" /fWhite %1 /fGray /s- . /s+ /p "Mana instalado (aŭ eble progresinta reĝimo sen deviga MBR) estas rekomendinda."
ERROR_Format="Eraro okazis dum provo formati diskon" /fWhite %1 /fGray /s- . /s+ /p /p "Malsama procezo estos bezonata por formati ĝin."
ERROR_FileSystem="Ne eblas pravalorizi provizoran spacon sur disko" /fWhite %1 /s- /fGray .
ERROR_CfgBackup="Ne eblas agordi sekurkopian dosierujon."
ERROR_MBRBackup="Ne eblas krei sekurkopion de la Master Boot Record por disko" /fWhite %1 /fGray /s- .
ERROR_SysFiles="Ne eblas kopii sistemdosierojn al disko" /fWhite %1 /fGray /s- .
ERROR_BootSector="Ne eblas ĝisdatigi la lanĉosektoron por disko" /fWhite %1 /fGray /s- .
ERROR_MBRUpdate="Ne eblas ĝisdatigi la lanĉosektoron por disko" /fWhite %1 /fGray /s- .
ERROR_Activate="Ne eblas agordi diskon" /fWhite %1 /fGray "al lanĉa particio" /fWhite %2 /fGray /s- .
ERROR_CfgFiles="Ne eblas instali novajn agordajn dosierojn sur disko" /fWhite %1 /fGray /s- .
ERROR_XfrFiles="Ne eblas duobligi bezonatan instalildosieron al" /fWhite %1 /fGray /s- .
ERROR_SAF="Problemo okazis dum elpakado de arkivo" /fWhite %1 /fGray "."
ERROR_WTF="Nekonata kaj neprobabla eraro okazis dum simpla operacio."
