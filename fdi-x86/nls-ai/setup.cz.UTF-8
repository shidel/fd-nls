# Welcome Message
WELCOME_DEF="Vítejte v instalačním programu systému" /fLightGreen %1 /fCyan %2 /fGray "."
WELCOME_ADV="Vítejte v" /fLightRed "pokročilé" /fGray "instalaci systému" /fLightGreen %1 /fCyan %2 /fGray /s- .
WELCOME_0=/p
WELCOME_1=/fLightGreen "%1" /fGray "je kompletní operační systém. Pokud se jej rozhodnete nainstalovat" /p "na svůj počítač, můžete " /fLightRed /BlinkOn "přepsat" /BlinkOff /fGray "stávající operační systém" /p "(například Windows.)" /fGray
WELCOME_2=/fGray /c32 "Pokud to není váš záměr, prosím" /fLightRed "zastavte HNED TEĎ!" /fGray
WELCOME_3=
WELCOME_4=
WELCOME_5=/fGray /p

HRULE=/fDarkGray /x 0xC4 /fGray

CONTINUE=/p "Chcete pokračovat" /c32
REBOOT=/p "Chcete nyní restartovat" /c32

AUTO_YES="[A,N]?" /fWhite "A" /fGray
AUTO_NO="[A,N]?" /fWhite "N" /fGray
AUTO_FMT=/s- "[U,R,N]?" /fWhite "R" /fGray

PROMPT_YESNO=/s AN
PROMPT_FMT=/s URN

ABORTED=/fLightRed "Instalace systému" %1 %2 "byla přerušena." /e /fGray /bBlack

PARTITION_AUTO="Automaticky rozdělit disk" /fWhite %1 /s- /fGray .
PARTITION_WARN=/fYellow "UPOZORNĚNÍ:" /fGray "Pro KERNL86 je vyžadován oddíl FAT16 menší než 2 GB."
PARTITION_MBR="Aktualizovat Master Boot Record na disku" /fWhite %1 /s- /fGray .
PARTITION_ACTIVE="Nastavit oddíl disku" /fWhite %1 /fGray "jako aktivní."
PARTITION_DONE=/p "Pro aktivaci nového rozdělení disku musíte restartovat počítač."

FORMAT="Disk" /fWhite %1 /fGray "se nezdá být naformátován."
FORMAT_DEF="Chcete disk naformátovat" /c32
FORMAT_ADV="Jak chcete disk naformátovat" /s- /c32 ( /fWhite "Ú" /fGray "plné," /c32 /fWhite "R" /fGray "ychlé," /c32 /fWhite "N" /fGray "e)" /c32

FILESYSTEM_TEST="Testování souborového systému na disku" /fWhite %1 /s- /fGray .
INSERT_DISKETTE="Vložte disketu" /fWhite #%1 /fGray (%2) "do" /fWhite %3 /fGray "."
PRESS_KEY="Pokračujte stisknutím klávesy."

TARGET_ASK="Kam si přejete nainstalovat" /fLightGreen %1 /s- /fGray "?" /c32
TARGET_PROMPT=/fWhite /bBlue %1
TARGET_BAD=/fLightRed "Požadován neplatný disk. Nelze instalovat na disketu."

CHANGE_PATH="Cesta" /fWhite %1 /fGray "již existuje." /p "Přejete si změnit instalační adresář" /c32

BACKUP_OLD="Na disku" /fWhite %1 /fGray "byl nalezen předchozí operační systém." /s+ /p "Chcete před instalací zálohovat staré soubory" /c32
BACKUP_ASK="Kam si přejete umístit záložní soubory?" /c32
BACKUP_PROMPT=/fWhite /bBlue %1
BACKUP_BAD=/fLightRed "Požadován neplatný cíl. Zálohu na toto místo nelze provést." /fGray

DELETE_OLD="Stávající soubory v" /fWhite %1 /fGray "mohou být jednoduše přepsány." /p "Chcete před instalací kompletně vymazat starý adresář" /c32

FORCE_MBR="Vynutit aktualizaci Master Boot Record na disku" /fWhite %1 /fGray /c32
SYS_FILES="Instalovat nové soubory zavádění systému na disk" /fWhite %1 /fGray /c32
CFG_FILES="Nahradit konfigurační soubory systému na disku" /fWhite %1 /fGray /c32

STATUS_MSG="Nastavení instalace:" /p
STATUS_CPU=/r4/c32 "Platforma (CPU)" /fWhite %1 /fGray (%2)
