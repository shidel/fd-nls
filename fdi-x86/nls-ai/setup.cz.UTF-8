INSTALL_NOW="Nyní jsme připraveni k instalaci systému" /fLightGreen %1 /fCyan %2 /fGray /s- .
EXTRACTION="Rozbalování souborů systému" /fLightGreen %1 /fCyan %2 /fGray /s- .
