DO_CFGFILES="Přenos nových konfiguračních souborů na disk" /fWhite %1 /fGray /s- .
DO_PREPARE="Příprava k instalaci spustitelných souborů a nástrojů."
DO_INSTALL="Instalace souborů" /fLightGreen %1 /fGray "pro" /fWhite %2 /fGray /s- .

DONE_NOW="Instalace systému" /fLightGreen %1 /fCyan %2 /fGray "byla dokončena."
REBOOT_NOW="Chcete nyní restartovat" /c32

REMOVE_MEDIA="Měli byste vyjmout všechny diskety a CD média."

