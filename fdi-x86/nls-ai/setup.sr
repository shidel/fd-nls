ERROR_CRITICAL=/fLightRed "КРИТИЧНА грешка:" /fGray /c32
ERROR_NoHDD="Није могуће пронаћи партиционисан и форматиран чврсти диск."
ERROR_MINOR=/fLightRed "грешка:" /fGray /c32
