# Welcome Message
WELCOME_DEF="Добродошли у инсталациони програм за" /fLightGreen %1 /fCyan %2 /fGray "."
WELCOME_ADV="Добродошли у" /fLightRed "напредни" /fGray "инсталатер за" /fLightGreen %1 /fCyan %2 /fGray /s- .
WELCOME_0=/p
WELCOME_1=/fLightGreen "%1" /fGray "је потпуни оперативни систем. Ако изаберете да га инсталирате" /p "на свој рачунар, можете " /fLightRed /BlinkOn "преписати" /BlinkOff /fGray "оперативни систем који тренутно имате" /p "(на пример, Windows.)" /fGray
WELCOME_2=/fGray /c32 "Ако ово није ваша намера, молимо" /fLightRed "зауставите се САДА!" /fGray
WELCOME_3=
WELCOME_4=
WELCOME_5=/fGray /p

HRULE=/fDarkGray /x 0xC4 /fGray

CONTINUE=/p "Желите ли да наставите" /c32
REBOOT=/p "Желите ли сада да поново покренете систем" /c32

AUTO_YES="[Y,N]?" /fWhite "Y" /fGray
AUTO_NO="[Y,N]?" /fWhite "N" /fGray
AUTO_FMT=/s- "[F,Q,N]?" /fWhite "Q" /fGray

PROMPT_YESNO=/s YN
PROMPT_FMT=/s FQN

ABORTED=/fLightRed "Инсталација система" %1 %2 "је прекинута." /e /fGray /bBlack

PARTITION_AUTO="Аутоматски партициониши диск" /fWhite %1 /s- /fGray .
PARTITION_WARN=/fYellow "ОБАВЕШТЕЊЕ:" /fGray "За KERNL86 је потребна FAT16 партиција мања од 2Гб."
PARTITION_MBR="Ажурирај Master Boot Record на диску" /fWhite %1 /s- /fGray .
PARTITION_ACTIVE="Постави партицију диска" /fWhite %1 /fGray "као активну."
PARTITION_DONE=/p "Морате поново покренути рачунар да би нова шема партиционисања ступила на снагу."

FORMAT="Изгледа да диск" /fWhite %1 /fGray "није форматиран."
FORMAT_DEF="Желите ли да форматирате свој диск" /c32
FORMAT_ADV="Како желите да форматирате свој диск" /s- /c32 ( /fWhite "П" /fGray "ун," /c32 /fWhite "Б" /fGray "рз," /c32 /fWhite "Н" /fGray "е)" /c32

FILESYSTEM_TEST="Тестирање фајл система на диску" /fWhite %1 /s- /fGray .
INSERT_DISKETTE="Уметните дискету" /fWhite #%1 /fGray (%2) "у" /fWhite %3 /fGray "."
PRESS_KEY="Притисните било који тастер за наставак."

TARGET_ASK="Где желите да инсталирате" /fLightGreen %1 /s- /fGray "?" /c32
TARGET_PROMPT=/fWhite /bBlue %1
TARGET_BAD=/fLightRed "Затражен је неважећи диск. Инсталација на дискету није могућа."

CHANGE_PATH="Путања" /fWhite %1 /fGray "већ постоји." /p "Желите ли да промените инсталациони директоријум" /c32

BACKUP_OLD="На диску" /fWhite %1 /fGray "је откривен претходни оперативни систем." /s+ /p "Желите ли да резервно копирате старе датотеке пре инсталације" /c32
BACKUP_ASK="Где желите да поставите резервне датотеке?" /c32
BACKUP_PROMPT=/fWhite /bBlue %1
BACKUP_BAD=/fLightRed "Затражено је неважеће одредиште. Резервна копија се не може направити на тој локацији." /fGray

DELETE_OLD="Постојеће датотеке у" /fWhite %1 /fGray "могу се једноставно преписати." /p "Желите ли да потпуно обришете стари директоријум пре инсталације" /c32

FORCE_MBR="Присили ажурирање Master Boot Record-а на диску" /fWhite %1 /fGray /c32
