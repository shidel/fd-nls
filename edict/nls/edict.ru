TITLE=Улучшенное средство создания образов дисков, версия %_ %s
COPYRIGHT=Copyright (c) 2018, Jerome Shidel

HELP_00="Информация о параметрах EDICT: "
HELP_01=
HELP_02="  /d <диск>      указать букву диска"
HELP_03="  /f <имя_файла> указать имя файла"
HELP_04="  /p <лимит>     ограничить макс. число дополнительных проходов"
HELP_05=
HELP_06="  /t <тип>       переопределить BIOS и выбрать настройки типа диска"
HELP_07="                 (0=360Kib, 1=1.2Mib, 2=720Kib, 3=1.44Mib, a=auto)"
HELP_08=
HELP_09="  /c <число>     переопределить число цилиндров/дорожек (0-1023)"
HELP_0a="  /r <число>     переопределить число сторон/головок на дорожку (0-255)"
HELP_0b="  /s <число>     переопределить число секторов на сторону (0-63)"
HELP_0c="  /b <число>     переопределить число байт в секторе (1-8192)"
HELP_0d=
HELP_0e="  /h             показать справку"

HELP_??="  /T             тест только для чтения"
HELP_??="  /w             записать образ на дискету"
HELP_??="  /v             проверить дискету"
HELP_??="  /i             только информация"
HELP_??="  /o             только один сектор"
HELP_??="  /q             тихий режим"
HELP_??="  /e             продолжить из существующего файла образа"
HELP_??="  /m <имя_файла> подключить файл образа (mount)"
HELP_??="  /u             отключить файл образа (unmount)"
HELP_??="  /l             список типов дисков"

INVALID=%r "Неверная команда: `" %s "'"
BAD_INT="Неверное числовое значение."
BAD_VAL="Значение вне диапазона."

DRIVE=Диск %_ %c: (ID 0x %b ) %_
DRIVE_TYPE=%_ (ID 0x %b )
DRIVE_TYPE_00=неизвестный тип дисковода
DRIVE_TYPE_01=дисковод '5.25"' 360Kib
DRIVE_TYPE_02=дисковод '5.25"' 1.2Mib
DRIVE_TYPE_03=дисковод '3.5"' 720Kib
DRIVE_TYPE_04=дисковод '3.5"' 1.44Mib
DRIVE_TYPE_05=другой тип дисковода

DRIVE_SPEC=%i %_ байт, %_ %I %_ секторов, %_ %I %_ дорожек, %_ %I %_ сторон(ы)

PASS_LIMIT=Разрешено до %_ %i %_ доп. проходов для чтения дискеты
BUFFERS=%i %_ байт буфер дискеты, %_ %i %_ байт буфер дорожки

PASS=Проход чтения дискеты № %i. Осталось секторов: %_ %i %_ .

READ_FAST=ЧТЕНИЕ ДОРОЖКИ: %_ %i, ГОЛОВКА: %_ %i
READ_SLOW=ЧТЕНИЕ ДОРОЖКИ: %_ %i, ГОЛОВКА: %_ %i, СЕКТОР: %_ %i

FAILED=Процесс создания образа не удался.
ABORTED=Процесс создания образа прерван.
COMPLETED=Процесс создания образа завершен.

BErr=%r "Код ошибки BIOS: 0x" %b %_ --> %_
BErr_01=неверная команда передана драйверу
BErr_02=адресная марка не найдена или плохой сектор
BErr_03=ошибка защиты записи на дискету
BErr_04=сектор не найден
BErr_05=ошибка сброса жесткого диска
BErr_06=дискета заменена или извлечена
BErr_07=неверная таблица параметров жесткого диска
BErr_08=переполнение DMA
BErr_09=доступ DMA через границу 64k
BErr_0a=плохой флаг сектора жесткого диска
BErr_0b=плохой цилиндр жесткого диска
BErr_0c=неподдерживаемая дорожка
BErr_0d=неверное число секторов в формате жесткого диска
BErr_0e=обнаружена адресная марка данных под управлением жесткого диска
BErr_0f=уровень арбитража DMA жесткого диска вне диапазона
BErr_10=ошибка ECC/CRC при чтении диска
BErr_11=исправимая ошибка данных жесткого диска, данные исправлены ECC
BErr_20=ошибка контроллера
BErr_40=ошибка позиционирования (seek failure)
BErr_80=дисковод не готов
BErr_aa=жесткий диск не готов
BErr_bb=неопределенная ошибка жесткого диска
BErr_cc=ошибка записи на жесткий диск на выбранном диске
BErr_e0=ошибка статуса жесткого диска
BErr_ff=операция опроса (sense) не удалась

DErr=%r "Код ошибки DOS: 0x" %b %_ --> %_
DErr_01=Неверный номер функции
DErr_02=Файл не найден
DErr_03=Путь не найден
DErr_04=Слишком много открытых файлов
DErr_05=Доступ запрещен
DErr_06=Неверный дескриптор (handle)
DErr_08=Недостаточно памяти
DErr_0f=Указан неверный диск
DErr_15=Диск не готов

