HELP_00="EDICT-asetusten tiedot: "
HELP_01=
HELP_02="  /d <asema>     m„„rit„ aseman kirjain"
HELP_03="  /f <tiedostonimi> m„„rit„ tiedoston nimi"
HELP_04="  /p <raja>      rajoita ylim„„r„isten lukukertojen enimm„ism„„r„"
HELP_05=
HELP_06="  /t <tyyppi>    ohita BIOS ja valitse asetukset levytyypin mukaan"
HELP_07="                 (0=360Kib, 1=1.2Mib, 2=720Kib, 3=1.44Mib, a=auto)"
HELP_08=
HELP_09="  /c <luku>      ohita sylinterien/urien m„„r„ (0-1023)"
HELP_0a="  /r <luku>      ohita puolien/p„iden m„„r„ uraa kohti (0-255)"
HELP_0b="  /s <luku>      ohita sektorien m„„r„ puolta kohti (0-63)"
HELP_0c="  /b <luku>      ohita tavujen m„„r„ sektoria kohti (1-8192)"
HELP_0d=
HELP_0e="  /h             n„yt„ ohjetiedot"

HELP_??="  /T             vain lukutesti"
HELP_??="  /w             kirjoita levykuva levykkeelle"
HELP_??="  /v             varmista levyke"
HELP_??="  /i             vain tiedot"
HELP_??="  /o             vain yksi sektori"
