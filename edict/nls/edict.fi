INVALID=%r "Virheellinen komento: `" %s "'"
BAD_INT="Virheellinen numeerinen arvo."
BAD_VAL="Arvo on sallitun alueen ulkopuolella."

DRIVE=Asema %_ %c: (ID 0x %b ) %_
DRIVE_TYPE=%_ (ID 0x %b )
DRIVE_TYPE_00=tuntematon asematyyppi
DRIVE_TYPE_01='5.25"' 360Kib asema
DRIVE_TYPE_02='5.25"' 1.2Mib asema
DRIVE_TYPE_03='3.5"' 720Kib asema
DRIVE_TYPE_04='3.5"' 1.44Mib asema
DRIVE_TYPE_05=muu asematyyppi

DRIVE_SPEC=%i %_ tavua, %_ %I %_ sektoria, %_ %I %_ uraa, %_ %I %_ puolta

PASS_LIMIT=Enint„„n %_ %i %_ ylim„„r„ist„ lukukertaa sallittu levykkeen lukemiseen
BUFFERS=%i %_ tavun levykepuskuri, %_ %i %_ tavun uran tulospuskuri

PASS=Levykkeen lukukerta nro %i. %_ %i %_ sektoria j„ljell„.

READ_FAST=LUE URA: %_ %i, PŽŽ: %_ %i
READ_SLOW=LUE URA: %_ %i, PŽŽ: %_ %i, SEKTORI: %_ %i

FAILED=Levykuvan luonti ep„onnistui.
ABORTED=Levykuvan luonti keskeytetty.
COMPLETED=Levykuvan luonti valmis.

BErr=%r "BIOS-virhekoodi: 0x" %b %_ --> %_
BErr_01=virheellinen komento v„litetty ohjaimelle
